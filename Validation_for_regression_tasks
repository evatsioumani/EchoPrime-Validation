def load_exclusion_list(filepath, id_col=None):
    """Φορτώνει λίστα εξαιρέσεων από .txt ή .csv αρχείο.
    
    - .txt: ένα ID ανά γραμμή (αγνοεί κενές γραμμές και γραμμές με #)
    - .csv: διαβάζει τη στήλη id_col (ή την πρώτη στήλη αν id_col=None)
    
    Επιστρέφει set με τα IDs προς εξαίρεση.
    """
    if filepath is None or not os.path.exists(filepath):
        return set()
    
    ext = os.path.splitext(filepath)[1].lower()
    
    if ext == '.csv':
        df_excl = pd.read_csv(filepath)
        col = id_col if id_col and id_col in df_excl.columns else df_excl.columns[0]
        ids = df_excl[col].dropna().astype(str).str.strip().tolist()
    else:
        # .txt ή οτιδήποτε άλλο — ένα ID ανά γραμμή
        with open(filepath, 'r', encoding='utf-8') as f:
            ids = [line.strip() for line in f 
                   if line.strip() and not line.strip().startswith('#')]
    
    return set(ids)


def try_parse_float(value):
    """Μετατρέπει σε αριθμό, αγνοώντας κείμενα ή κενά."""
    if value is None or pd.isna(value):
        return None
    try:
        return float(str(value).strip())
    except (ValueError, TypeError):
        return None


def parse_ef_range(value):
    """Αναγνωρίζει range (π.χ. '50-55', '45 - 50') και επιστρέφει τον μέσο όρο."""
    if value is None or pd.isna(value):
        return None
    s = str(value).strip()
    # Μοτίβο: αριθμός - αριθμός (με ή χωρίς κενά/%)
    m = re.match(r'(\d+(?:\.\d+)?)\s*[-–]\s*(\d+(?:\.\d+)?)', s)
    if m:
        lo, hi = float(m.group(1)), float(m.group(2))
        return (lo + hi) / 2.0
    return None

def parse_ef_modifier(value):
    """Αναγνωρίζει modifier (π.χ. '>55', '≥50', '<30') και επιστρέφει το κάτω άκρο.
    
    Λογική:
      >X  / ≥X  → κάτω άκρο = X
      <X  / ≤X  → κάτω άκρο = X (δεν εφαρμόζεται εδώ, 
                   αλλά αν υπάρχει, χρησιμοποιούμε τον αριθμό)
    """
    if value is None or pd.isna(value):
        return None
    s = str(value).strip()
    # Μοτίβο: (>|≥|>=|<|≤|<=) αριθμός
    m = re.match(r'[^\d]*(\d+(?:\.\d+)?)', s)
    if m:
        return float(m.group(1))
    return None

def resolve_ef_value(row, exact_col, range_col, mod_col):
    """Επιλύει την τιμή EF με προτεραιότητα: exact > range (μ.ο.) > modifier (κάτω άκρο).
    
    Επιστρέφει (float_value, source_label) ή (None, 'not_found').
    """
    # 1. Ακριβής τιμή
    v = try_parse_float(row.get(exact_col))
    if v is not None:
        return v, 'exact'
    
    # 2. Range → μέσος όρος
    v = parse_ef_range(row.get(range_col))
    if v is not None:
        return v, 'range'
    
    # 3. Modifier → κάτω άκρο
    v = parse_ef_modifier(row.get(mod_col))
    if v is not None:
        return v, 'modifier'
    
    return None, 'not_found'


def bootstrap_metrics(y_true, y_pred, n_bootstraps, seed):
    """Υπολογισμός 95% Διαστημάτων Εμπιστοσύνης (Confidence Intervals)."""
    rng = np.random.RandomState(seed)
    mae_list, rmse_list, r2_list = [], [], []

    for _ in tqdm(range(n_bootstraps), desc="  Bootstrapping", leave=False):
        idx = rng.randint(0, len(y_true), len(y_true))
        yt, yp = y_true[idx], y_pred[idx]
        mae_list.append(mean_absolute_error(yt, yp))
        rmse_list.append(np.sqrt(mean_squared_error(yt, yp)))
        r2_list.append(r2_score(yt, yp))

    def ci(lst):
        return np.percentile(lst, 2.5), np.percentile(lst, 97.5)

    return ci(mae_list), ci(rmse_list), ci(r2_list)

def evaluate_metric(df, gt_col, pred_col, metric_name):
    """Αξιολογεί μια συγκεκριμένη μέτρηση (π.χ. μόνο το EF ή μόνο το RVSP)."""
    # Κρατάμε μόνο τις γραμμές όπου έχουμε έγκυρο αριθμό ΚΑΙ στο GT ΚΑΙ στο Pred
    df_valid = df[df[gt_col].notna() & df[pred_col].notna()].copy()
    
    if len(df_valid) < 2:
        return None, df_valid, "Ανεπαρκή δεδομένα για αυτή τη μέτρηση."

    y_true = df_valid[gt_col].values
    y_pred = df_valid[pred_col].values

    point_mae  = mean_absolute_error(y_true, y_pred)
    point_rmse = np.sqrt(mean_squared_error(y_true, y_pred))
    point_r2   = r2_score(y_true, y_pred)

    mae_ci, rmse_ci, r2_ci = bootstrap_metrics(y_true, y_pred, N_BOOTSTRAPS, RANDOM_SEED)

    results = {
        "Metric_Name": metric_name,
        "N": len(df_valid),
        "MAE": point_mae, "MAE_CI": mae_ci,
        "RMSE": point_rmse, "RMSE_CI": rmse_ci,
        "R2": point_r2, "R2_CI": r2_ci,
        "GT_Mean": y_true.mean(), "GT_Std": y_true.std(),
        "Pred_Mean": y_pred.mean(), "Pred_Std": y_pred.std(),
    }
    return results, df_valid, None

