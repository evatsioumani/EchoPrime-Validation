import os
import re
import numpy as np
import pandas as pd
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score
from tqdm import tqdm

# =============================================================================
# EXECUTION PARAMETERS 
# =============================================================================

GROUND_TRUTH_FILE = r"path/to/ef_rvsp_ground_truth_merged.csv"
PREDICTIONS_FILE  = r"path/to/predictions_merged.csv"
OUTPUT_RESULTS    = r"path/to/output_directory/echoprime_combined_regression_results.xlsx"

# Exclusion list file
# Supports .txt (one ID per line) or .csv (column with IDs)
# Set to None if no exclusions are needed
EXCLUSION_FILE    = r"path/to/merged_ids_exclusion_list.txt"
EXCLUSION_ID_COL  = None # For .csv: name of the column with IDs. Ignored for .txt.

# Column names for patient IDs (used for merging)
ID_COL_GT   = "exam_id"
ID_COL_PRED = "study_id"

# Column names - Ground Truth
GT_EF_COL       = "ef_exact"
GT_EF_RANGE_COL = "ef_range"      # e.g., "50-55", "45 - 50"
GT_EF_MOD_COL   = "ef_modifier"   # e.g., ">55", ">=50", "<30"
GT_RVSP_COL     = "rvsp_exact"

# Column names - Predictions 
PRED_EF_COL   = "ejection_fraction"
PRED_RVSP_COL = "pulmonary_artery_pressure_continuous"  

N_BOOTSTRAPS = 10000
RANDOM_SEED  = 42

# =============================================================================
# COMPUTATION FUNCTIONS
# =============================================================================

def load_exclusion_list(filepath, id_col=None):
    """
    Loads an exclusion list from a .txt or .csv file.
    
    - .txt: one ID per line (ignores empty lines and lines starting with #)
    - .csv: reads the id_col column (or the first column if id_col=None)
    
    Returns a set containing the IDs to be excluded.
    """
    if filepath is None or not os.path.exists(filepath):
        return set()
    
    ext = os.path.splitext(filepath)[1].lower()
    
    if ext == '.csv':
        df_excl = pd.read_csv(filepath)
        col = id_col if id_col and id_col in df_excl.columns else df_excl.columns[0]
        ids = df_excl[col].dropna().astype(str).str.strip().tolist()
    else:
        # .txt or any other format — one ID per line
        with open(filepath, 'r', encoding='utf-8') as f:
            ids = [line.strip() for line in f 
                   if line.strip() and not line.strip().startswith('#')]
    
    return set(ids)


def try_parse_float(value):
    """Converts to float, ignoring non-numeric text or NaNs."""
    if value is None or pd.isna(value):
        return None
    try:
        return float(str(value).strip())
    except (ValueError, TypeError):
        return None


def parse_ef_range(value):
    """Parses a range string (e.g., '50-55', '45 - 50') and returns the average."""
    if value is None or pd.isna(value):
        return None
    s = str(value).strip()
    # Pattern: number - number (with or without spaces/%)
    m = re.match(r'(\d+(?:\.\d+)?)\s*[-–]\s*(\d+(?:\.\d+)?)', s)
    if m:
        lo, hi = float(m.group(1)), float(m.group(2))
        return (lo + hi) / 2.0
    return None

def parse_ef_modifier(value):
    """
    Parses a modifier string (e.g., '>55', '>=50', '<30') and returns the boundary.
    
    Logic:
      >X  / >=X  -> lower bound = X
      <X  / <=X  -> upper bound = X (not actively applied as upper, 
                    but extracts the numeric value if present)
    """
    if value is None or pd.isna(value):
        return None
    s = str(value).strip()
    # Pattern: (>|>=|>=|<|<=|<=) number
    m = re.match(r'[^\d]*(\d+(?:\.\d+)?)', s)
    if m:
        return float(m.group(1))
    return None

def resolve_ef_value(row, exact_col, range_col, mod_col):
    """
    Resolves the EF value with priority: exact > range (average) > modifier (boundary).
    
    Returns (float_value, source_label) or (None, 'not_found').
    """
    # 1. Exact value
    v = try_parse_float(row.get(exact_col))
    if v is not None:
        return v, 'exact'
    
    # 2. Range -> calculate average
    v = parse_ef_range(row.get(range_col))
    if v is not None:
        return v, 'range'
    
    # 3. Modifier -> extract boundary
    v = parse_ef_modifier(row.get(mod_col))
    if v is not None:
        return v, 'modifier'
    
    return None, 'not_found'


def bootstrap_metrics(y_true, y_pred, n_bootstraps, seed):
    """Calculates 95% Confidence Intervals using bootstrapping."""
    rng = np.random.RandomState(seed)
    mae_list, rmse_list, r2_list = [], [], []

    for _ in tqdm(range(n_bootstraps), desc="  Bootstrapping", leave=False):
        idx = rng.randint(0, len(y_true), len(y_true))
        yt, yp = y_true[idx], y_pred[idx]
        mae_list.append(mean_absolute_error(yt, yp))
        rmse_list.append(np.sqrt(mean_squared_error(yt, yp)))
        r2_list.append(r2_score(yt, yp))

    def ci(lst):
        return np.percentile(lst, 2.5), np.percentile(lst, 97.5)

    return ci(mae_list), ci(rmse_list), ci(r2_list)

def evaluate_metric(df, gt_col, pred_col, metric_name):
    """Evaluates a specific regression metric (e.g., only EF or only RVSP)."""
    # Keep only rows with valid numeric values in BOTH ground truth and predictions
    df_valid = df[df[gt_col].notna() & df[pred_col].notna()].copy()
    
    if len(df_valid) < 2:
        return None, df_valid, "Insufficient data to compute this metric."

    y_true = df_valid[gt_col].values
    y_pred = df_valid[pred_col].values

    point_mae  = mean_absolute_error(y_true, y_pred)
    point_rmse = np.sqrt(mean_squared_error(y_true, y_pred))
    point_r2   = r2_score(y_true, y_pred)

    mae_ci, rmse_ci, r2_ci = bootstrap_metrics(y_true, y_pred, N_BOOTSTRAPS, RANDOM_SEED)

    results = {
        "Metric_Name": metric_name,
        "N": len(df_valid),
        "MAE": point_mae, "MAE_CI": mae_ci,
        "RMSE": point_rmse, "RMSE_CI": rmse_ci,
        "R2": point_r2, "R2_CI": r2_ci,
        "GT_Mean": y_true.mean(), "GT_Std": y_true.std(),
        "Pred_Mean": y_pred.mean(), "Pred_Std": y_pred.std(),
    }
    return results, df_valid, None

# =============================================================================
# MAIN PIPELINE
# =============================================================================

def run_evaluation():
    print("=" * 70)
    print(" EchoPrime — Combined Regression Evaluator (EF & RVSP)")
    print("=" * 70)

    # 1. Load files
    try:
        df_gt = pd.read_csv(GROUND_TRUTH_FILE)
        df_pred = pd.read_csv(PREDICTIONS_FILE)
    except FileNotFoundError as e:
        print(f"\n[ERROR] File not found: {e.filename}")
        return

    # Verify required columns exist
    for col, df, name in [(ID_COL_GT, df_gt, "GT"), (ID_COL_PRED, df_pred, "Pred")]:
        if col not in df.columns:
            print(f"[ERROR] Column '{col}' not found in {name} file.")
            return

    print(f"\nLoaded:")
    print(f"  Ground truth: {len(df_gt)} examinations")
    print(f"  Predictions : {len(df_pred)} examinations")

    # --- Load Exclusion List ---
    exclusion_ids = load_exclusion_list(EXCLUSION_FILE, EXCLUSION_ID_COL)
    if exclusion_ids:
        print(f"  Exclusion list: {len(exclusion_ids)} IDs to exclude")
        
        # Exclude from both dataframes prior to merging
        before_gt = len(df_gt)
        before_pred = len(df_pred)
        df_gt = df_gt[~df_gt[ID_COL_GT].astype(str).str.strip().isin(exclusion_ids)]
        df_pred = df_pred[~df_pred[ID_COL_PRED].astype(str).str.strip().isin(exclusion_ids)]
        
        excluded_gt = before_gt - len(df_gt)
        excluded_pred = before_pred - len(df_pred)
        print(f"  Excluded      : {excluded_gt} from GT, {excluded_pred} from Predictions")
    else:
        if EXCLUSION_FILE is not None:
            print(f"  Exclusion list: (empty or file not found)")

    # 2. Preparation for merge
    df_gt = df_gt.rename(columns={ID_COL_GT: 'unified_id'})
    df_pred = df_pred.rename(columns={ID_COL_PRED: 'unified_id'})
    
    # Outer merge to identify missing matches
    df_all = pd.merge(df_gt, df_pred, on='unified_id', how='outer', indicator=True)
    
    missing_issues = []
    
    for _, row in df_all[df_all['_merge'] != 'both'].iterrows():
        sid = row['unified_id']
        reason = "Present only in Ground Truth" if row['_merge'] == 'left_only' else "Present only in Predictions"
        missing_issues.append({'study_id': sid, 'Issue': reason})

    df = df_all[df_all['_merge'] == 'both'].copy()
    print(f"  Matched       : {len(df)} examinations")

    # 3. Data cleaning and numeric conversion
    #    EF: consolidate exact / range / modifier
    ef_cols_present = all(c in df.columns for c in [GT_EF_COL, GT_EF_RANGE_COL, GT_EF_MOD_COL])
    if ef_cols_present:
        resolved = df.apply(
            lambda row: resolve_ef_value(row, GT_EF_COL, GT_EF_RANGE_COL, GT_EF_MOD_COL),
            axis=1, result_type='expand'
        )
        df['gt_ef'] = resolved[0]
        df['ef_source'] = resolved[1]
        
        # Source reporting
        src_counts = df['ef_source'].value_counts()
        print(f"\n  GT EF value sources:")
        for src in ['exact', 'range', 'modifier', 'not_found']:
            cnt = src_counts.get(src, 0)
            print(f"    {src:12s}: {cnt}")
    elif GT_EF_COL in df.columns:
        df['gt_ef'] = df[GT_EF_COL].apply(try_parse_float)
        df['ef_source'] = df['gt_ef'].apply(lambda x: 'exact' if x is not None else 'not_found')
    else:
        df['gt_ef'] = None
        df['ef_source'] = 'not_found'
    
    df['pred_ef'] = df[PRED_EF_COL].apply(try_parse_float) if PRED_EF_COL in df.columns else None
    
    df['gt_rvsp'] = df[GT_RVSP_COL].apply(try_parse_float) if GT_RVSP_COL in df.columns else None
    df['pred_rvsp'] = df[PRED_RVSP_COL].apply(try_parse_float) if PRED_RVSP_COL in df.columns else None

    # 4. Evaluate EF
    print(f"\n[{' EF (Ejection Fraction) ':^66}]")
    print("-" * 70)
    res_ef, df_ef, err_ef = evaluate_metric(df, 'gt_ef', 'pred_ef', 'Ejection Fraction (%)')
    if res_ef:
        print(f" Evaluated                : {res_ef['N']} examinations")
        print(f" MAE (Mean Absolute Error): {res_ef['MAE']:.3f}  (95% CI: {res_ef['MAE_CI'][0]:.3f} - {res_ef['MAE_CI'][1]:.3f})")
        print(f" RMSE                     : {res_ef['RMSE']:.3f}  (95% CI: {res_ef['RMSE_CI'][0]:.3f} - {res_ef['RMSE_CI'][1]:.3f})")
        print(f" R² (Accuracy)            : {res_ef['R2']:.3f}  (95% CI: {res_ef['R2_CI'][0]:.3f} - {res_ef['R2_CI'][1]:.3f})")
    else:
        print(f" ⚠ {err_ef}")

    # 5. Evaluate RVSP
    print(f"\n[{' RVSP (Right Ventricular Systolic Pressure) ':^66}]")
    print("-" * 70)
    res_rvsp, df_rvsp, err_rvsp = evaluate_metric(df, 'gt_rvsp', 'pred_rvsp', 'RVSP (mmHg)')
    if res_rvsp:
        print(f" Evaluated                : {res_rvsp['N']} examinations")
        print(f" MAE (Mean Absolute Error): {res_rvsp['MAE']:.3f}  (95% CI: {res_rvsp['MAE_CI'][0]:.3f} - {res_rvsp['MAE_CI'][1]:.3f})")
        print(f" RMSE                     : {res_rvsp['RMSE']:.3f}  (95% CI: {res_rvsp['RMSE_CI'][0]:.3f} - {res_rvsp['RMSE_CI'][1]:.3f})")
        print(f" R² (Accuracy)            : {res_rvsp['R2']:.3f}  (95% CI: {res_rvsp['R2_CI'][0]:.3f} - {res_rvsp['R2_CI'][1]:.3f})")
    else:
        print(f" ⚠ {err_rvsp}")

    # 6. Export to Excel
    print("\n" + "=" * 70)
    print(" SAVING RESULTS")
    print("=" * 70)

    # Sheet 1: Summary
    summary_rows = []
    for res in [res_ef, res_rvsp]:
        if res:
            summary_rows.extend([
                {"Metric": res['Metric_Name'], "Statistic": "N (Count)", "Value": res['N'], "95% CI": ""},
                {"Metric": res['Metric_Name'], "Statistic": "MAE", "Value": round(res['MAE'], 3), "95% CI": f"[{res['MAE_CI'][0]:.3f}, {res['MAE_CI'][1]:.3f}]"},
                {"Metric": res['Metric_Name'], "Statistic": "RMSE", "Value": round(res['RMSE'], 3), "95% CI": f"[{res['RMSE_CI'][0]:.3f}, {res['RMSE_CI'][1]:.3f}]"},
                {"Metric": res['Metric_Name'], "Statistic": "R²", "Value": round(res['R2'], 3), "95% CI": f"[{res['R2_CI'][0]:.3f}, {res['R2_CI'][1]:.3f}]"},
                {"Metric": res['Metric_Name'], "Statistic": "GT Mean ± Std", "Value": f"{res['GT_Mean']:.2f} ± {res['GT_Std']:.2f}", "95% CI": ""},
                {"Metric": res['Metric_Name'], "Statistic": "Pred Mean ± Std", "Value": f"{res['Pred_Mean']:.2f} ± {res['Pred_Std']:.2f}", "95% CI": ""},
            ])
    
    # EF value sources (for transparency)
    if ef_cols_present and 'ef_source' in df.columns:
        src_counts = df['ef_source'].value_counts()
        for src in ['exact', 'range', 'modifier']:
            cnt = src_counts.get(src, 0)
            if cnt > 0:
                summary_rows.append({"Metric": "EF Source Breakdown", "Statistic": f"from_{src}", "Value": cnt, "95% CI": ""})
    
    df_summary = pd.DataFrame(summary_rows)

    # Sheets 2 & 3: Patient-level details
    if res_ef:
        df_ef = df_ef[['unified_id', 'gt_ef', 'pred_ef', 'ef_source']].copy()
        df_ef.columns = ['Study_ID', 'GT_EF', 'Pred_EF', 'EF_Source']
        df_ef['Abs_Error'] = (df_ef['GT_EF'] - df_ef['Pred_EF']).abs().round(2)
        
    if res_rvsp:
        df_rvsp = df_rvsp[['unified_id', 'gt_rvsp', 'pred_rvsp']].copy()
        df_rvsp.columns = ['Study_ID', 'GT_RVSP', 'Pred_RVSP']
        df_rvsp['Abs_Error'] = (df_rvsp['GT_RVSP'] - df_rvsp['Pred_RVSP']).abs().round(2)

    # Sheet 4: Issues/Exclusions
    df_missing = pd.DataFrame(missing_issues)

    # Write to Excel
    os.makedirs(os.path.dirname(OUTPUT_RESULTS), exist_ok=True)
    with pd.ExcelWriter(OUTPUT_RESULTS, engine='openpyxl') as writer:
        df_summary.to_excel(writer, sheet_name='Summary Metrics', index=False)
        if res_ef:
            df_ef.to_excel(writer, sheet_name='Details_EF', index=False)
        if res_rvsp:
            df_rvsp.to_excel(writer, sheet_name='Details_RVSP', index=False)
        if not df_missing.empty:
            df_missing.to_excel(writer, sheet_name='Missing_or_Unmatched', index=False)
        if exclusion_ids:
            df_excluded = pd.DataFrame({'Excluded_Study_ID': sorted(exclusion_ids)})
            df_excluded.to_excel(writer, sheet_name='Excluded_IDs', index=False)

    print(f" ✓ Excel successfully saved to:\n   {OUTPUT_RESULTS}\n")


if __name__ == '__main__':
    run_evaluation()
