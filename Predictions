"""
EchoPrime — Batch Inference Script
===================================
Automated batch processing pipeline for the EchoPrime model.
Ensures deterministic execution, handles incremental saving (crash-safe),
and supports resume capabilities.
"""

import gc
import json
import logging
import os
import random
import traceback
import sys
from pathlib import Path
from datetime import datetime

import numpy as np
import pandas as pd
import torch
from tqdm import tqdm


# ─── Logging setup ────────────────────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[logging.StreamHandler()],
)
log = logging.getLogger("EchoPrimeBatch")


# ─── Determinism ──────────────────────────────────────────────────────────────
def set_deterministic(seed: int = 42) -> None:
    """
    Ensures fully reproducible inference across runs.

    Covers:
      - Python / NumPy / PyTorch RNG seeds
      - cuDNN deterministic mode (disables autotuner)
      - CUBLAS workspace for deterministic GEMM
      - torch.use_deterministic_algorithms (PyTorch >= 1.8)

    WARNING: torch.use_deterministic_algorithms(True) might raise a
    RuntimeError if an operation lacks a deterministic implementation.
    In that case, change to warn_only=True below.
    """
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark     = False
    os.environ["CUBLAS_WORKSPACE_CONFIG"] = ":4096:8"
    try:
        torch.use_deterministic_algorithms(True)
    except AttributeError:
        # PyTorch < 1.8 — not supported, continue normally
        log.warning("torch.use_deterministic_algorithms unavailable "
                    "(PyTorch < 1.8) — partial determinism applied.")
    except RuntimeError as e:
        # Some operation lacks a deterministic implementation
        log.warning(f"use_deterministic_algorithms(True) failed: {e}\n"
                    "Consider using warn_only=True if necessary.")
    log.info(f"Deterministic mode enabled (seed={seed})")


# ─── Stress Echo exclusion list ───────────────────────────────────────────────
def load_exclusion_list(exclusion_list_path) -> set:
    """
    Reads a .txt file containing one study_id per line to be excluded.
    Lines starting with '#' are treated as comments and ignored.
    """
    if exclusion_list_path is None:
        return set()

    path = Path(exclusion_list_path)
    if not path.exists():
        log.warning(
            f"Exclusion list not found: {path} — proceeding without exclusions."
        )
        return set()

    ids = set()
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if line and not line.startswith("#"):
            ids.add(line)

    log.info(f"Exclusion list loaded: {len(ids)} studies will be skipped.")
    return ids


# ─── Study discovery ──────────────────────────────────────────────────────────
def discover_studies(dataset_root: Path, exclusion_ids: set) -> list:
    """
    Returns a sorted list of study folders that:
      - Are NOT in the exclusion list.
      - Contain at least one .dcm file in their 'echo/' subfolder.

    Sorting ensures deterministic processing order regardless of the filesystem.
    """
    studies         = []
    skipped_stress  = 0
    skipped_novideo = 0

    for folder in sorted(dataset_root.iterdir()):
        if not folder.is_dir():
            continue

        study_id = folder.name

        # Check exclusion list
        if study_id in exclusion_ids:
            log.info(f"  [EXCLUDED — In exclusion list] {study_id}")
            skipped_stress += 1
            continue

        # Check for 'echo/' subfolder and .dcm files
        echo_folder = folder / "echo"
        if not echo_folder.exists():
            log.warning(f"  [SKIPPED — No echo/ folder found] {study_id}")
            skipped_novideo += 1
            continue

        dcm_files = list(echo_folder.glob("*.dcm"))
        if not dcm_files:
            log.warning(f"  [SKIPPED — No .dcm files found] {study_id}")
            skipped_novideo += 1
            continue

        studies.append(folder)

    log.info(
        f"Discovery: {len(studies)} studies to process | "
        f"{skipped_stress} excluded | "
        f"{skipped_novideo} skipped (no .dcm)"
    )
    return studies


# ─── Inference for a single study ─────────────────────────────────────────────
def run_single_study(ep, study_path: Path):
    """
    Executes the standard pipeline (Preprocessing -> Encoding -> Prediction)
    for a single study. Returns a dictionary with phenotypes or None if it fails.
    """
    study_id    = study_path.name
    echo_folder = str(study_path / "echo")

    # ── Step 1: Preprocessing ─────────────────────────────────────────────
    try:
        stack_of_videos = ep.process_dicoms(echo_folder)
    except Exception:
        log.error(
            f"  [PREPROCESSING FAILED] {study_id}\n{traceback.format_exc()}"
        )
        return None

    if stack_of_videos is None or stack_of_videos.shape[0] == 0:
        log.warning(f"  [EMPTY] {study_id} — no valid videos found.")
        return None

    log.debug(f"  {study_id}: {stack_of_videos.shape[0]} videos loaded.")

    # ── Step 2: Encoding ──────────────────────────────────────────────────
    try:
        encoded_study = ep.encode_study(stack_of_videos)
    except Exception:
        log.error(
            f"  [ENCODING FAILED] {study_id}\n{traceback.format_exc()}"
        )
        return None
    finally:
        # Free RAM/VRAM after encoding
        del stack_of_videos
        if torch.cuda.is_available():
            torch.cuda.empty_cache()
        gc.collect()

    # ── Step 3: Prediction ────────────────────────────────────────────────
    try:
        preds = ep.predict_metrics(encoded_study)
    except Exception:
        log.error(
            f"  [PREDICTION FAILED] {study_id}\n{traceback.format_exc()}"
        )
        return None
    finally:
        del encoded_study
        gc.collect()

    return preds


# ─── Batch loop ───────────────────────────────────────────────────────────────
def run_batch(
    ep,
    studies: list,
    output_dir: Path,
    existing_df: pd.DataFrame = None,
) -> pd.DataFrame:
    """
    Processes all studies and saves results incrementally to a CSV after
    each study to prevent data loss in case of a crash.

    If 'existing_df' is provided (resume mode), it retains the previous
    results and appends the new ones.
    """
    results_path = output_dir / "predictions_raw_.csv"
    failed_path  = output_dir / "failed_studies.txt"

    # Load existing results if resuming
    if existing_df is not None and not existing_df.empty:
        all_rows = existing_df.to_dict("records")
        log.info(f"  Loaded {len(all_rows)} existing records into memory.")
    else:
        all_rows = []

    failed = []

    for study_path in tqdm(studies, desc="Processing studies", unit="study"):
        study_id = study_path.name

        preds = run_single_study(ep, study_path)

        if preds is None:
            failed.append(study_id)
            continue

        row = {"study_id": study_id, **preds}
        all_rows.append(row)

        # Incremental save (crash-safe)
        pd.DataFrame(all_rows).to_csv(results_path, index=False)

    if failed:
        failed_path.write_text("\n".join(failed), encoding="utf-8")
        log.warning(f"{len(failed)} studies failed — see {failed_path}")

    df = pd.DataFrame(all_rows)
    log.info(f"Predictions saved to → {results_path}  ({len(df)} studies)")
    return df


# ─── Main ─────────────────────────────────────────────────────────────────────
def main(dataset_root, output_dir, exclusion_list, device, resume,
         max_studies=None):

    dataset_root = Path(dataset_root)
    output_dir   = Path(output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)

    # Set deterministic mode before any computations
    SEED = 42
    set_deterministic(seed=SEED)

    # Save run configuration for reproducibility
    run_config = {
        "dataset_root":   str(dataset_root),
        "output_dir":     str(output_dir),
        "exclusion_list": str(exclusion_list),
        "device":         device,
        "resume":         resume,
        "max_studies":    max_studies,
        "seed":           SEED,
        "timestamp":      datetime.now().isoformat(),
    }
    (output_dir / "run_config.json").write_text(
        json.dumps(run_config, indent=2), encoding="utf-8"
    )

    # Load exclusion list
    exclusion_ids = load_exclusion_list(exclusion_list)

    # Load Model
    log.info("Loading EchoPrime model...")
    
    # Define the local path to the EchoPrime repository folder
    ECHOPRIME_DIR = r"path/to/EchoPrime"  
    if ECHOPRIME_DIR not in sys.path:
        sys.path.insert(0, ECHOPRIME_DIR)

    from echo_prime.model import EchoPrime
    try:
         ep = EchoPrime(device=device)
         log.info(f"Model loaded with device={device}.")
    except TypeError:
         log.warning("EchoPrime() does not accept arguments — falling back to auto-detect device.")
         ep = EchoPrime()
         log.info("Model loaded (auto-detect device).")  

    # Discover studies
    studies = discover_studies(dataset_root, exclusion_ids)

    # Handle resume mode
    existing_df = None
    if resume:
        done_path = output_dir / "predictions_raw_.csv"
        if done_path.exists():
            existing_df = pd.read_csv(done_path)
            done_ids    = set(existing_df["study_id"].astype(str))
            before      = len(studies)
            studies     = [s for s in studies if s.name not in done_ids]
            log.info(
                f"Resume mode: skipping {before - len(studies)} "
                f"already processed studies "
                f"({len(existing_df)} rows loaded)."
            )

    if not studies:
        log.info("No studies left to process.")
        return

    # ── Pilot mode ───────────────────────────────────────────────────────────
    # If max_studies=N, process only the first N studies.
    # Results are saved in a separate 'pilot' folder to avoid mixing with main data.
    if max_studies is not None:
        studies = studies[:max_studies]
        log.info(
            f"[PILOT MODE] Running on {len(studies)} studies "
            f"(max_studies={max_studies})"
        )
        pilot_output_dir = output_dir / "pilot"
        pilot_output_dir.mkdir(parents=True, exist_ok=True)
        active_output_dir = pilot_output_dir
        # Ensure fresh start for pilot runs
        active_existing_df = None
    else:
        active_output_dir  = output_dir
        active_existing_df = existing_df

    # Run the batch inference
    predictions_df = run_batch(
        ep,
        studies,
        active_output_dir,
        existing_df=active_existing_df,
    )

    log.info(
        f"Processing completed. "
        f"Total: {len(predictions_df)} studies → "
        f"{active_output_dir / 'predictions_raw_.csv'}"
    )


# =============================================================================
#  CONFIGURATION — Update these paths before running
# =============================================================================
if __name__ == "__main__":

    DATASET_ROOT   = r"path/to/dataset"
    OUTPUT_DIR     = r"path/to/output_directory"
    EXCLUSION_LIST = r"path/to/exclusion_list.txt"  # Set to None if not needed

    DEVICE         = "cuda"   # "cuda" for GPU, "cpu" otherwise
    RESUME         = False    # Set to True to resume from previous run

    # ── Pilot mode setup ─────────────────────────────────────────────────────
    # MAX_STUDIES = 10   -> Processes only the first 10 studies for testing
    # MAX_STUDIES = None -> Processes the entire dataset
    MAX_STUDIES    = None

    main(
        dataset_root   = DATASET_ROOT,
        output_dir     = OUTPUT_DIR,
        exclusion_list = EXCLUSION_LIST,
        device         = DEVICE,
        resume         = RESUME,
        max_studies    = MAX_STUDIES,
    )
